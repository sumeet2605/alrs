# Alluring Lens Studios - Environment Example
# Copy this file to .env for local development.
# Keep real credentials out of Git.

ENVIRONMENT=local
APP_NAME="Alluring Lens Studios API"
API_HOST=0.0.0.0
API_PORT=8000

# FastAPI CORS origins. Comma-separated.
ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# SQLite local example:
# SQLALCHEMY_DATABASE_URL=sqlite:///./alrs.db
# PostgreSQL example:
SQLALCHEMY_DATABASE_URL=postgresql://alrs_user:alrs_password@localhost:5432/alrs_db

# Admin/auth placeholders
ADMIN_API_KEY=example_admin_api_key
SECRET_KEY=example_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=example_admin_password

# Storage backend: local | gcs | spaces
STORAGE_BACKEND=local
MEDIA_ROOT=./media

# Google Cloud Storage, required only when STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=
GCS_SIGNED_URL_EXP_SECONDS=3600
GCS_CREDENTIALS_JSON=
GCP_PROJECT_ID=

# DigitalOcean Spaces / S3-compatible storage, required only when STORAGE_BACKEND=spaces
SPACES_BUCKET=
SPACES_REGION=
SPACES_ENDPOINT=
SPACES_KEY=
SPACES_SECRET=

# WhatsApp Cloud API placeholders
WHATSAPP_VERIFY_TOKEN=example_whatsapp_verify_token
WHATSAPP_TOKEN=example_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=example_phone_number_id
WHATSAPP_APP_SECRET=example_meta_app_secret

# Email / notifications
RESEND_API_KEY=
FROM_EMAIL=no-reply@example.com

# Frontend
VITE_API_BASE_URL=http://localhost:8000
